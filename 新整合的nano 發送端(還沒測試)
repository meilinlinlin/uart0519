/* USART2 完整收到一個 Nano Byte 時立即記錄 DWT 時間 */
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
  uint32_t now_cycle;

  if (huart->Instance != USART2)
  {
    return;
  }

  now_cycle = DWT->CYCCNT;

  if (nano_event_pending == 0U)
  {
    nano_pending_code = nano_rx_byte;
    nano_pending_uart_cycle = now_cycle;

    /* 把 PC8 這一組標記與 UART Byte 綁在一起 */
    nano_pending_start_cycle = nano_marker_start_cycle;
    nano_pending_done_cycle = nano_marker_done_cycle;
    nano_pending_marker_valid = nano_marker_valid;

    nano_event_pending = 1U;
  }
  else
  {
    /* 主程式尚未處理上一筆，這筆不覆蓋，僅記錄遺失次數 */
    nano_dropped_count++;
  }

  /* 立刻準備接收下一個 Byte */
  (void)HAL_UART_Receive_IT(&huart2,
                            &nano_rx_byte,
                            1U);
}

void HAL_UART_ErrorCallback(UART_HandleTypeDef *huart)
{
  if (huart->Instance != USART2)
  {
    return;
  }

  /* 清除 overrun，重新啟動一個 Byte 的中斷接收 */
  __HAL_UART_CLEAR_OREFLAG(huart);

  (void)HAL_UART_Receive_IT(&huart2,
                            &nano_rx_byte,
                            1U);
}

void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
  uint32_t now_cycle;

  now_cycle = DWT->CYCCNT;

  /* PC8：Nano 辨識開始／完成標記，使用雙邊緣中斷 */
  if (GPIO_Pin == GPIO_PIN_8)
  {
    if (HAL_GPIO_ReadPin(GPIOC, GPIO_PIN_8) == GPIO_PIN_SET)
    {
      /* 上升緣：Nano 開始辨識 */
      nano_marker_start_cycle = now_cycle;
      nano_marker_valid = 0U;
    }
    else
    {
      /* 下降緣：Nano 完成判定，下一步應立即送 USART2 */
      nano_marker_done_cycle = now_cycle;
      nano_marker_valid = 1U;
    }

    return;
  }

  /* PC9：監看 PA8，只抓新事件第一包的第一個 PWM 上升緣 */
  if (GPIO_Pin == GPIO_PIN_9)
  {
    if (timing_ir_monitor_armed != 0U)
    {
      timing_ir_tx_start_cycle = now_cycle;

      timing_ir_wait_us =
          DWT_BetweenUs(timing_event_start_cycle,
                        timing_ir_tx_start_cycle);

      if (timing_uart_event_valid != 0U)
      {
        timing_stm32_to_ir_us =
            DWT_BetweenUs(timing_uart_done_cycle,
                          timing_ir_tx_start_cycle);
      }

      if (timing_nano_mark_valid != 0U)
      {
        timing_nano_done_to_ir_us =
            DWT_BetweenUs(timing_nano_done_cycle,
                          timing_ir_tx_start_cycle);

        timing_nano_start_to_ir_us =
            DWT_BetweenUs(timing_nano_start_cycle,
                          timing_ir_tx_start_cycle);
      }

      timing_ir_monitor_armed = 0U;

      /* 取得第一個邊緣後關閉 EXTI9，避免 38 kHz 持續進中斷 */
      EXTI->IMR &= ~GPIO_PIN_9;
    }

    return;
  }
}

