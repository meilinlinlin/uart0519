static void UART_Print(const char *msg)
{
  uint16_t len = 0U;

  while (msg[len] != '\0')
  {
    len++;
  }

  HAL_UART_Transmit(&huart4,
                    (uint8_t *)msg,
                    len,
                    HAL_MAX_DELAY);
}

/*
 * STM32F407 Cortex-M4 DWT 微秒延遲。
 * NEC 時序需要 us 等級，不能使用 HAL_Delay() 取代。
 */
static void DWT_Delay_Init(void)
{
  CoreDebug->DEMCR |= CoreDebug_DEMCR_TRCENA_Msk;

  DWT->CYCCNT = 0U;
  DWT->CTRL |= DWT_CTRL_CYCCNTENA_Msk;
}

static void delay_us(uint32_t us)
{
  uint32_t start_tick;
  uint32_t delay_ticks;

  start_tick = DWT->CYCCNT;
  delay_ticks = us * (SystemCoreClock / 1000000U);

  while ((DWT->CYCCNT - start_tick) < delay_ticks)
  {
  }
}
static uint32_t DWT_ElapsedUs(uint32_t start_cycle)
{
  uint32_t elapsed_cycles;

  elapsed_cycles = DWT->CYCCNT - start_cycle;

  return elapsed_cycles /
         (SystemCoreClock / 1000000U);
}

static uint32_t DWT_BetweenUs(uint32_t start_cycle,
                              uint32_t end_cycle)
{
  uint32_t elapsed_cycles;

  elapsed_cycles = end_cycle - start_cycle;

  return elapsed_cycles /
         (SystemCoreClock / 1000000U);
}
/* PA8 / TIM1_CH1 38 kHz carrier */
static void IR_CarrierOn(void)
{
  __HAL_TIM_SET_COMPARE(&htim1,
                        TIM_CHANNEL_1,
                        IR_PWM_DUTY);
}

static void IR_CarrierOff(void)
{
  __HAL_TIM_SET_COMPARE(&htim1,
                        TIM_CHANNEL_1,
                        0U);
}

static void IR_SendStart(void)
{
  IR_CarrierOn();
  delay_us(IR_START_ON_US);

  IR_CarrierOff();
  delay_us(IR_START_OFF_US);
}

static void IR_SendBit(uint8_t bitValue)
{
  IR_CarrierOn();
  delay_us(IR_BIT_MARK_US);

  IR_CarrierOff();

  if (bitValue != 0U)
  {
    delay_us(IR_ONE_SPACE_US);
  }
  else
  {
    delay_us(IR_ZERO_SPACE_US);
  }
}

static void IR_SendStop(void)
{
  IR_CarrierOn();
  delay_us(IR_STOP_MARK_US);

  IR_CarrierOff();
}
static void LCD_UpdateEvent(uint8_t event_type, uint8_t level)
{
  uint32_t lcd_start_cycle;

  /*
   * 預設這次沒有重新更新 LCD。
   * 如果相同畫面直接 return，LCD 時間會是 0。
   */
  timing_lcd_us = 0U;

  /*
   * 狀態相同就不重新繪圖，避免 LCD 閃爍。
   */
  if ((lcd_last_event_type == event_type) &&
      (lcd_last_level == level))
  {
    return;
  }

  lcd_last_event_type = event_type;
  lcd_last_level = level;

  /*
   * 開始測量整張畫面的更新時間。
   */
  lcd_start_cycle = DWT->CYCCNT;

  if (event_type == IR_TYPE_ERROR)
  {
    LCD_ShowSystemErrorScreen();
  }
  else if ((event_type == IR_TYPE_NONE) &&
           (level == IR_LEVEL_NONE))
  {
    LCD_ShowSafeScreen();
  }
  else if ((event_type == IR_TYPE_VRU_CROSS) &&
           (level == IR_LEVEL_1))
  {
    LCD_ShowLevel1Screen();
  }
  else if ((event_type == IR_TYPE_VRU_CROSS) &&
           (level == IR_LEVEL_2))
  {
    LCD_ShowLevel2Screen();
  }
  else if ((event_type == IR_TYPE_VRU_CROSS) &&
           (level == IR_LEVEL_3))
  {
    LCD_ShowLevel3Screen();
  }
  else if ((event_type == IR_TYPE_BRAKE) &&
          (level == IR_LEVEL_1))
  {
    LCD_ShowBrakeLevel1Screen();
  }
  else if ((event_type == IR_TYPE_BRAKE) &&
           (level == IR_LEVEL_2))
  {
    LCD_ShowBrakeLevel2Screen();
  }
  else if ((event_type == IR_TYPE_BRAKE) &&
          (level == IR_LEVEL_3))
  {
    LCD_ShowBrakeLevel3Screen();
  }
  else
  {
    LCD_ShowSystemErrorScreen();
  }

  /*
   * 畫面函式執行結束後，SPI 資料已經傳送完成。
   */
  timing_lcd_us =
      DWT_ElapsedUs(lcd_start_cycle);
}
/*
 * Payload：
 *
 * TTT LL CCC
 *
 * TTT：event type
 * LL ：warning level
 * CCC：TTT XOR 0LL
 */
/*
 * CRC-2 生成多項式：
 *
 * G(x) = x^2 + x + 1
 * 二進位表示為 111，也就是 0x07。
 *
 * 傳入資料格式：
 * TTLL，共4 bit。
 *
 * 回傳：
 * 2 bit CRC。
 */
static uint8_t IR_CalculateCRC2(uint8_t data4)
{
  uint8_t remainder;
  int8_t bit;

  /*
   * 只保留低4 bit，並在後面補2個0。
   *
   * 例如：
   * data4 = 0110
   * remainder = 011000
   */
  remainder = (uint8_t)((data4 & 0x0FU) << 2);

  /*
   * 使用 111 做模二除法。
   * 模二除法中的減法就是 XOR。
   */
  for (bit = 5; bit >= 2; bit--)
  {
    if ((remainder & (1U << bit)) != 0U)
    {
      remainder ^= (uint8_t)(0x07U << (bit - 2));
    }
  }

  /*
   * 最後只保留2 bit餘數。
   */
  return remainder & 0x03U;
}

/*
 * 6-bit Payload：
 *
 * TT LL CC
 *
 * TT：事件種類，2 bit
 * LL：事件等級，2 bit
 * CC：CRC-2，2 bit
 */
static uint8_t IR_MakePayload(uint8_t event_type,
                              uint8_t level)
{
  uint8_t data4;
  uint8_t crc2;

  /*
   * 將事件種類與等級組成4 bit：
   *
   * TTLL
   */
  data4 = (uint8_t)(((event_type & 0x03U) << 2) |
                     (level & 0x03U));

  crc2 = IR_CalculateCRC2(data4);

  /*
   * 組成：
   *
   * TTLLCC
   */
  return (uint8_t)((data4 << 2) | crc2);
}

/*
 * 6-bit Payload，MSB first。
 *
 * 傳送順序：
 * bit5 → bit4 → bit3 → bit2 → bit1 → bit0
 */
static void IR_SendPayload6(uint8_t payload)
{
  int8_t i;

  payload &= 0x3FU;

  for (i = 5; i >= 0; i--)
  {
    IR_SendBit((payload >> i) & 0x01U);
  }
}

static void IR_SendCurrentEvent(void)
{
  uint8_t payload;
  uint32_t ir_start_cycle;
  uint8_t is_first_tx;

  payload = IR_MakePayload(current_event_type,
                           current_level);

  is_first_tx = timing_first_tx_pending;

  /*
   * 新事件第一包發送前，開啟 PC9 EXTI。
   * PC9 必須以跳線接到 PA8，才能量到「實際 PWM 第一個上升緣」。
   */
  if (is_first_tx != 0U)
  {
    timing_ir_tx_start_cycle = 0U;
    timing_ir_wait_us = 0U;
    timing_stm32_to_ir_us = 0U;
    timing_nano_done_to_ir_us = 0U;
    timing_nano_start_to_ir_us = 0U;
    timing_ir_monitor_armed = 1U;

    __HAL_GPIO_EXTI_CLEAR_IT(GPIO_PIN_9);
    EXTI->IMR |= GPIO_PIN_9;
  }

  /* 量測一包完整 6-bit IR 的軟體執行時間 */
  ir_start_cycle = DWT->CYCCNT;

  IR_SendStart();
  IR_SendPayload6(payload);
  IR_SendStop();
  IR_CarrierOff();

  timing_ir_tx_us = DWT_ElapsedUs(ir_start_cycle);

  if (is_first_tx != 0U)
  {
    timing_first_tx_pending = 0U;

    /*
     * 若 PC9 沒有接線或 EXTI 未設定，避免量測旗標一直保持開啟。
     * 此時與實際 IR 起始相關的數值會維持 0。
     */
    if (timing_ir_monitor_armed != 0U)
    {
      timing_ir_monitor_armed = 0U;
      EXTI->IMR &= ~GPIO_PIN_9;
    }
  }
}
/* 計時結果輸出 */
static void Timing_PrintResult(uint8_t event_type,
                               uint8_t level)
{
  char log_msg[520];
  uint8_t payload;

  payload = IR_MakePayload(event_type, level);
  timing_sequence++;

  /*
   * 所有時間都已在 IR、LCD 完成前記錄完畢，
   * 因此現在才透過 UART4 印出，不會污染本次量測。
   */
  snprintf(
      log_msg,
      sizeof(log_msg),
      "TIME,SEQ=%lu,CODE=0x%02X,TYPE=%u,LEVEL=%u,PAYLOAD=0x%02X,"
      "MARK=%u,NANO_INFER=%lu us,NANO_TO_UART=%lu us,"
      "UART_TO_PROCESS=%lu us,PROCESS_TO_IR=%lu us,UART_TO_IR=%lu us,"
      "NANO_DONE_TO_IR=%lu us,NANO_START_TO_IR=%lu us,"
      "IR_TX=%lu us,LCD=%lu us,PROCESS_TO_LCD=%lu us,"
      "UART_TO_LCD=%lu us,NANO_DONE_TO_LCD=%lu us,"
      "NANO_START_TO_LCD=%lu us,DROPPED=%lu\r\n",
      (unsigned long)timing_sequence,
      (unsigned int)timing_rx_code,
      (unsigned int)event_type,
      (unsigned int)level,
      (unsigned int)payload,
      (unsigned int)timing_nano_mark_valid,
      (unsigned long)timing_nano_inference_us,
      (unsigned long)timing_nano_to_uart_us,
      (unsigned long)timing_uart_to_process_us,
      (unsigned long)timing_ir_wait_us,
      (unsigned long)timing_stm32_to_ir_us,
      (unsigned long)timing_nano_done_to_ir_us,
      (unsigned long)timing_nano_start_to_ir_us,
      (unsigned long)timing_ir_tx_us,
      (unsigned long)timing_lcd_us,
      (unsigned long)timing_total_to_lcd_us,
      (unsigned long)timing_uart_to_lcd_us,
      (unsigned long)timing_nano_done_to_lcd_us,
      (unsigned long)timing_nano_start_to_lcd_us,
      (unsigned long)nano_dropped_count
  );

  UART_Print(log_msg);

  /* 只清除目前事件快照，不動 PC8 的下一組最新標記 */
  timing_uart_event_valid = 0U;
  timing_nano_mark_valid = 0U;
}

static void Set_Event(uint8_t event_type,
                      uint8_t level)
{
  uint32_t lcd_done_cycle;

  timing_event_start_cycle = DWT->CYCCNT;

  /* 清除上一筆結果 */
  timing_nano_inference_us = 0U;
  timing_nano_to_uart_us = 0U;
  timing_uart_to_process_us = 0U;
  timing_ir_wait_us = 0U;
  timing_stm32_to_ir_us = 0U;
  timing_nano_done_to_ir_us = 0U;
  timing_nano_start_to_ir_us = 0U;
  timing_ir_tx_us = 0U;
  timing_lcd_us = 0U;
  timing_total_to_lcd_us = 0U;
  timing_uart_to_lcd_us = 0U;
  timing_nano_done_to_lcd_us = 0U;
  timing_nano_start_to_lcd_us = 0U;

  if (timing_uart_event_valid != 0U)
  {
    timing_uart_to_process_us =
        DWT_BetweenUs(timing_uart_done_cycle,
                      timing_event_start_cycle);
  }

  if (timing_nano_mark_valid != 0U)
  {
    timing_nano_inference_us =
        DWT_BetweenUs(timing_nano_start_cycle,
                      timing_nano_done_cycle);

    timing_nano_to_uart_us =
        DWT_BetweenUs(timing_nano_done_cycle,
                      timing_uart_done_cycle);
  }

  timing_first_tx_pending = 1U;

  current_event_type = event_type;
  current_level = level;

  force_send_now = 1U;
  last_send_tick = HAL_GetTick();

  /* 先發 IR，再更新前車 LCD */
  IR_Process();
  LCD_UpdateEvent(event_type, level);

  lcd_done_cycle = DWT->CYCCNT;

  timing_total_to_lcd_us =
      DWT_BetweenUs(timing_event_start_cycle,
                    lcd_done_cycle);

  if (timing_uart_event_valid != 0U)
  {
    timing_uart_to_lcd_us =
        DWT_BetweenUs(timing_uart_done_cycle,
                      lcd_done_cycle);
  }

  if (timing_nano_mark_valid != 0U)
  {
    timing_nano_done_to_lcd_us =
        DWT_BetweenUs(timing_nano_done_cycle,
                      lcd_done_cycle);

    timing_nano_start_to_lcd_us =
        DWT_BetweenUs(timing_nano_start_cycle,
                      lcd_done_cycle);
  }

  Timing_PrintResult(event_type, level);
}

static void Process_Nano_Event(void)
{
  uint8_t rx_data;
  uint32_t uart_cycle;
  uint32_t nano_start_cycle;
  uint32_t nano_done_cycle;
  uint8_t marker_valid;

  if (nano_event_pending == 0U)
  {
    return;
  }

  /* 很短暫地關閉中斷，完整取出 ISR 快照 */
  __disable_irq();

  rx_data = nano_pending_code;
  uart_cycle = nano_pending_uart_cycle;
  nano_start_cycle = nano_pending_start_cycle;
  nano_done_cycle = nano_pending_done_cycle;
  marker_valid = nano_pending_marker_valid;
  nano_event_pending = 0U;

  __enable_irq();

  timing_rx_code = rx_data;
  timing_uart_done_cycle = uart_cycle;
  timing_nano_start_cycle = nano_start_cycle;
  timing_nano_done_cycle = nano_done_cycle;
  timing_uart_event_valid = 1U;
  timing_nano_mark_valid = marker_valid;

  switch (rx_data)
  {
    case NANO_CODE_SAFE:
      Set_Event(IR_TYPE_NONE,
                IR_LEVEL_NONE);
      break;

    case NANO_CODE_LEVEL_1:
      Set_Event(IR_TYPE_VRU_CROSS,
                IR_LEVEL_1);
      break;

    case NANO_CODE_LEVEL_2:
      Set_Event(IR_TYPE_VRU_CROSS,
                IR_LEVEL_2);
      break;

    case NANO_CODE_LEVEL_3:
      Set_Event(IR_TYPE_VRU_CROSS,
                IR_LEVEL_3);
      break;

    default:
    {
      char invalid_msg[64];

      snprintf(invalid_msg,
               sizeof(invalid_msg),
               "Invalid Nano event code: 0x%02X\r\n",
               (unsigned int)rx_data);
      UART_Print(invalid_msg);

      timing_uart_event_valid = 0U;
      timing_nano_mark_valid = 0U;
      break;
    }
  }
}

static void IR_Process(void)
{
  uint32_t now;
  uint32_t period_ms;

  now = HAL_GetTick();

  /*
 * SAFE 狀態：
 * 每隔固定時間持續發送 00000000，
 * 直到目前狀態改變。
 */
if ((current_event_type == IR_TYPE_NONE) &&
    (current_level == IR_LEVEL_NONE))
{
  if ((force_send_now != 0U) ||
      ((now - last_send_tick) >= IR_SAFE_PERIOD_MS))
  {
    IR_SendCurrentEvent();

    last_send_tick = now;
    force_send_now = 0U;

    //UART_Print("TX SAFE 00000000\r\n");
  }

  return;
}

  /*
   * 系統錯誤每 300 ms 發送一次；
   * 一般事件每 150 ms 發送一次。
   */
  if (current_event_type == IR_TYPE_ERROR)
  {
    period_ms = IR_ERROR_PERIOD_MS;
  }
  else
  {
    period_ms = IR_EVENT_PERIOD_MS;
  }

  if ((force_send_now != 0U) ||
      ((now - last_send_tick) >= period_ms))
  {
    IR_SendCurrentEvent();

    last_send_tick = now;
    force_send_now = 0U;
  }
}

