#include "main.h"

/* Private define ------------------------------------------------------------*/
/* USER CODE BEGIN PD */
#define BIT_TIME_MS   40
#define FRAME_GAP_MS  100
/* USER CODE END PD */

/* Private variables ---------------------------------------------------------*/
TIM_HandleTypeDef htim1;
UART_HandleTypeDef huart4;

/* USER CODE BEGIN PV */
static const char irPattern[] = "0101";
/* USER CODE END PV */

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_UART4_Init(void);
static void MX_TIM1_Init(void);

/* USER CODE BEGIN PFP */
static void IR_CarrierOn(void);
static void IR_CarrierOff(void);
static void IR_SendBit(char bitValue);
static void IR_SendPattern(void);
/* USER CODE END PFP */

/* Private user code ---------------------------------------------------------*/
/* USER CODE BEGIN 0 */
static void IR_CarrierOn(void)
{
  // PA8 / TIM1_CH1 輸出 38kHz PWM
  HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);

  // 送 1 時亮 LD5，方便確認程式有沒有跑
  HAL_GPIO_WritePin(GPIOD, LD5_Pin, GPIO_PIN_SET);
}

static void IR_CarrierOff(void)
{
  // PA8 / TIM1_CH1 停止輸出 PWM
  HAL_TIM_PWM_Stop(&htim1, TIM_CHANNEL_1);

  // 送 0 時關 LD5
  HAL_GPIO_WritePin(GPIOD, LD5_Pin, GPIO_PIN_RESET);
}

static void IR_SendBit(char bitValue)
{
  if (bitValue == '1')
  {
    IR_CarrierOn();
    HAL_UART_Transmit(&huart4, (uint8_t*)"1", 1, HAL_MAX_DELAY);
  }
  else
  {
    IR_CarrierOff();
    HAL_UART_Transmit(&huart4, (uint8_t*)"0", 1, HAL_MAX_DELAY);
  }

  HAL_Delay(BIT_TIME_MS);
}

static void IR_SendPattern(void)
{
  for (uint8_t i = 0; irPattern[i] != '\0'; i++)
  {
    IR_SendBit(irPattern[i]);
  }

  HAL_UART_Transmit(&huart4, (uint8_t*)"\r\n", 2, HAL_MAX_DELAY);
}
/* USER CODE END 0 */

/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  HAL_Init();
  SystemClock_Config();

  MX_GPIO_Init();
  MX_UART4_Init();
  MX_TIM1_Init();

  /* USER CODE BEGIN 2 */
  IR_CarrierOff();

  uint8_t startupMsg[] = "STM32 IR TX Ready\r\n";
  HAL_UART_Transmit(&huart4, startupMsg, sizeof(startupMsg) - 1, HAL_MAX_DELAY);
  HAL_UART_Transmit(&huart4, (uint8_t*)"Send pattern: 0101\r\n", 20, HAL_MAX_DELAY);
  /* USER CODE END 2 */

  while (1)
  {
    /* USER CODE BEGIN 3 */
    IR_SendPattern();
    HAL_Delay(FRAME_GAP_MS);
    /* USER CODE END 3 */
  }
}

