static void UART_Print(const char *msg)
{
  uint16_t len = 0;

  while (msg[len] != '\0')
  {
    len++;
  }

  HAL_UART_Transmit(&huart4, (uint8_t *)msg, len, HAL_MAX_DELAY);
}

static void Panel_ShowSafe(void)
{
  // 安全：LD4 亮，LD5 關
  HAL_GPIO_WritePin(GPIOD, LD4_Pin, GPIO_PIN_SET);
  HAL_GPIO_WritePin(GPIOD, LD3_Pin | LD5_Pin | LD6_Pin, GPIO_PIN_RESET);
}

static void Panel_ShowWarning(void)
{
  // 警示：LD5 亮，LD4 關
  HAL_GPIO_WritePin(GPIOD, LD5_Pin, GPIO_PIN_SET);
  HAL_GPIO_WritePin(GPIOD, LD3_Pin | LD4_Pin | LD6_Pin, GPIO_PIN_RESET);
}

static void IR_CarrierOn(void)
{
  // PA8 / TIM1_CH1 輸出 38kHz PWM
  HAL_TIM_PWM_Start(&htim1, TIM_CHANNEL_1);
}

static void IR_CarrierOff(void)
{
  // PA8 / TIM1_CH1 停止輸出 PWM
  HAL_TIM_PWM_Stop(&htim1, TIM_CHANNEL_1);
}

static void IR_SendBit(char bitValue)
{
  if (bitValue == '1')
  {
    IR_CarrierOn();
    HAL_Delay(BIT_TIME_MS);
  }
  else
  {
    IR_CarrierOff();
    HAL_Delay(BIT_TIME_MS);
  }
}

static void IR_SendPattern(void)
{
  for (uint8_t i = 0; irPattern[i] != '\0'; i++)
  {
    IR_SendBit(irPattern[i]);
  }

  // 很重要：0101 最後一碼是 1，所以送完一定要關掉 IR
  IR_CarrierOff();
}

static void IR_Test5s(void)
{
  UART_Print("\r\nTEST: IR ON for 5 seconds\r\n");

  HAL_GPIO_WritePin(GPIOD, LD5_Pin, GPIO_PIN_SET);
  HAL_GPIO_WritePin(GPIOD, LD4_Pin, GPIO_PIN_RESET);

  IR_CarrierOn();
  HAL_Delay(TEST_TIME_MS);
  IR_CarrierOff();

  HAL_GPIO_WritePin(GPIOD, LD5_Pin, GPIO_PIN_RESET);

  if (tx_state == 1)
  {
    Panel_ShowWarning();
  }
  else
  {
    Panel_ShowSafe();
  }

  UART_Print("TEST finished\r\n");
}

static void Check_UART_Command(void)
{
  uint8_t rxData;

  // timeout 1ms，不要卡死等 UART
  if (HAL_UART_Receive(&huart4, &rxData, 1, 1) == HAL_OK)
  {
    if (rxData == '1')
    {
      tx_state = 1;

      Panel_ShowWarning();

      UART_Print("\r\nCMD 1 received\r\n");
      UART_Print("Mode: WARNING, keep sending 0101\r\n");
    }
    else if (rxData == '0')
    {
      tx_state = 0;

      IR_CarrierOff();
      HAL_TIM_PWM_Stop(&htim1, TIM_CHANNEL_1);

      Panel_ShowSafe();

      UART_Print("\r\nCMD 0 received\r\n");
      UART_Print("Mode: SAFE, IR OFF\r\n");
    }
    else if (rxData == 't' || rxData == 'T')
    {
      IR_Test5s();
    }
    else if (rxData == '\r' || rxData == '\n')
    {
      // ignore Enter
    }
    else
    {
      UART_Print("\r\nInvalid command. Type 0, 1, or t.\r\n");
    }
  }
}

/* USER CODE END 0 */

int main(void)
{
  HAL_Init();
  SystemClock_Config();

  MX_GPIO_Init();
  MX_UART4_Init();
  MX_TIM1_Init();

  /* USER CODE BEGIN 2 */

  IR_CarrierOff();
  tx_state = 0;
  Panel_ShowSafe();

  // 開機閃一下 LD5，確認新程式真的有跑
  HAL_GPIO_WritePin(GPIOD, LD5_Pin, GPIO_PIN_SET);
  HAL_Delay(300);
  HAL_GPIO_WritePin(GPIOD, LD5_Pin, GPIO_PIN_RESET);
  HAL_Delay(300);

  Panel_ShowSafe();

  UART_Print("\r\nSTM32 IR TX Ready\r\n");
  UART_Print("Type 0, 1, or t in Python terminal.\r\n");
  UART_Print("0 = SAFE, IR OFF\r\n");
  UART_Print("1 = WARNING, keep sending 0101\r\n");
  UART_Print("t = TEST, IR ON for 5 seconds\r\n\r\n");

  /* USER CODE END 2 */

  while (1)
  {
    /* USER CODE BEGIN 3 */

    Check_UART_Command();

    if (tx_state == 1)
    {
      Panel_ShowWarning();

      // 持續送 0101
      IR_SendPattern();

      // pattern 送完會先關 IR，然後等下一組
      HAL_Delay(FRAME_GAP_MS);
    }
    else
    {
      // 安全模式：強制 IR 關閉
      IR_CarrierOff();
      Panel_ShowSafe();
      HAL_Delay(20);
    }

    /* USER CODE END 3 */
  }
}

